datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String           @id @default(uuid())
  firebaseUid String           @unique
  displayName String
  email       String
  createdAt   DateTime         @default(now())
  bankConnections BankConnection[]
  goals       Goal[]
  ownedFamilies   Family[]
  familyMemberships FamilyMember[]
  sentInvites     FamilyInvite[] @relation("SentInvites")
}

model BankConnection {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String        @default("gocardless") // gocardless, fints
  institutionId String
  requisitionId String        @unique
  referenceId   String        @unique
  status        String        @default("linked") // linked, expired, revoked
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      BankAccount[]

  @@index([userId])
}

model BankAccount {
  id               String         @id @default(uuid())
  externalId       String         @unique // Provider-specific account ID
  name             String?        // Account name from bank
  ownerName        String?        // Account owner name from bank
  accountType      String         @default("cash") // cash, investment
  bankConnectionId String
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id])
  includedInTotal  Boolean        @default(true)
  lastSyncedAt     DateTime?      // Last transaction sync timestamp
  createdAt        DateTime       @default(now())
  balances         Balance[]
  transactions     Transaction[]
  goals            GoalAccount[]

  @@index([bankConnectionId])
}

model Transaction {
  id                    String      @id @default(uuid())
  bankAccountId         String
  bankAccount           BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  externalId            String      @unique
  amount                Decimal
  currency              String
  description           String
  mandateReference      String?
  creditorId            String?
  remittanceInformation String?
  date                  DateTime
  createdAt             DateTime    @default(now())

  @@index([bankAccountId])
  @@index([bankAccountId, date])
}

model Balance {
  id            String      @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount          Decimal
  currency        String      // e.g. "EUR", "GBP"
  balanceType     String      // e.g. "interimAvailable", "expected"
  gainAmount      Decimal?    // Investment accounts: absolute gain/loss
  gainPercentage  Decimal?    // Investment accounts: gain/loss as percentage
  fetchedAt       DateTime    @default(now())

  @@index([bankAccountId])
  @@index([bankAccountId, fetchedAt])
}

enum SavingsInterval {
  weekly
  monthly
}

enum GoalType {
  balance_based
  transaction_based
}

model Goal {
  id            String           @id @default(uuid())
  name          String
  goalType      GoalType         @default(balance_based)
  targetAmount  Decimal
  initialAmount Decimal          @default(0)
  matchPattern  String?          // Transaction description substring match (case-insensitive)
  currency      String
  deadline      DateTime
  interval      SavingsInterval
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      GoalAccount[]

  @@index([userId])
}

model Family {
  id        String         @id @default(uuid())
  name      String
  ownerId   String
  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   FamilyMember[]
  invites   FamilyInvite[]

  @@index([ownerId])
}

model FamilyMember {
  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([familyId, userId])
  @@index([userId])
}

enum InviteStatus {
  pending
  accepted
  declined
  expired
}

model FamilyInvite {
  id          String       @id @default(uuid())
  familyId    String
  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User         @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  email       String
  status      InviteStatus @default(pending)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@index([familyId])
  @@index([email])
}

model GoalAccount {
  goalId    String
  goal      Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  accountId String
  account   BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([goalId, accountId])
  @@index([accountId])
}
