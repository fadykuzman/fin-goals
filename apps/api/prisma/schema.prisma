datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model BankConnection {
  id            String        @id @default(uuid())
  userId        String        // placeholder until auth is implemented
  institutionId String
  requisitionId String        @unique
  referenceId   String        @unique
  status        String        @default("linked") // linked, expired, revoked
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      BankAccount[]

  @@index([userId])
}

model BankAccount {
  id               String         @id @default(uuid())
  externalId       String         @unique // GoCardless account ID
  name             String?        // Account name from bank
  ownerName        String?        // Account owner name from bank
  bankConnectionId String
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id])
  includedInTotal  Boolean        @default(true)
  createdAt        DateTime       @default(now())
  balances         Balance[]

  @@index([bankConnectionId])
}

model Balance {
  id            String      @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount        Decimal
  currency      String      // e.g. "EUR", "GBP"
  balanceType   String      // e.g. "interimAvailable", "expected"
  fetchedAt     DateTime    @default(now())

  @@index([bankAccountId])
  @@index([bankAccountId, fetchedAt])
}
